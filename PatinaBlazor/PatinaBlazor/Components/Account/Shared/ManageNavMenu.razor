@using Microsoft.AspNetCore.Identity
@using PatinaBlazor.Data

@inject SignInManager<ApplicationUser> SignInManager

<ul class="nav flex-column manage-nav">
    <li class="nav-item">
        <NavLink class="nav-link manage-nav-link" href="Account/Manage" Match="NavLinkMatch.All">
            <i class="bi bi-person-fill"></i> Profile
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link manage-nav-link" href="Account/Manage/Email">
            <i class="bi bi-envelope-fill"></i> Email
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link manage-nav-link" href="Account/Manage/ChangePassword">
            <i class="bi bi-lock-fill"></i> Password
        </NavLink>
    </li>
    @if (hasExternalLogins)
    {
        <li class="nav-item">
            <NavLink class="nav-link manage-nav-link" href="Account/Manage/ExternalLogins">
                <i class="bi bi-box-arrow-in-right"></i> External logins
            </NavLink>
        </li>
    }
</ul>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
